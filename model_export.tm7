:type="a:ArrayOfstring"><a:string>Not Selected</a:string><a:string>No</a:string><a:string>Yes</a:string></b:Value><b:SelectedIndex>0</b:SelectedIndex></a:anyType><a:anyType i:type="b:ListDisplayAttribute" xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:DisplayName>Destination Authenticated</b:DisplayName><b:Name>authenticatesDestination</b:Name><b:Value i:type="a:ArrayOfstring"><a:string>No</a:string><a:string>Yes</a:string></b:Value><b:SelectedIndex>0</b:SelectedIndex></a:anyType><a:anyType i:type="b:ListDisplayAttribute" xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:DisplayName>Provides Confidentiality</b:DisplayName><b:Name>providesConfidentiality</b:Name><b:Value i:type="a:ArrayOfstring"><a:string>No</a:string><a:string>Yes</a:string></b:Value><b:SelectedIndex>0</b:SelectedIndex></a:anyType><a:anyType i:type="b:ListDisplayAttribute" xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:DisplayName>Provides Integrity</b:DisplayName><b:Name>providesIntegrity</b:Name><b:Value i:type="a:ArrayOfstring"><a:string>No</a:string><a:string>Yes</a:string></b:Value><b:SelectedIndex>0</b:SelectedIndex></a:anyType></Properties><TypeId xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">GE.DF</TypeId><HandleX xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">510</HandleX><HandleY xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">485</HandleY><PortSource xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">South</PortSource><PortTarget xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">North</PortTarget><SourceGuid xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">b6060006-0006-4b06-ab06-060000000006</SourceGuid><SourceX xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">480</SourceX><SourceY xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">410</SourceY><TargetGuid xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">c6d60006-d006-4c06-ac06-d60000000006</TargetGuid><TargetX xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">540</TargetX><TargetY xmlns="http://schemas.datacontract.org/2004/07/ThreatModeling.Model.Abstracts">560</TargetY></a:Value></a:KeyValueOfguidanyType></Lines><Zoom>1</Zoom></DrawingSurfaceModel></DrawingSurfaceList><MetaInformation><Assumptions>1. All external communication uses TLS 1.2+. 2. API Gateway is the single entry point. 3. Internal services on private network. 4. Payment via Razorpay/PayU. 5. Ekart for logistics. 6. Mobile apps and web browsers as clients.</Assumptions><Contributors>Secure Software Engineering - BITS Pilani Sem 3</Contributors><ExternalDependencies>Razorpay/PayU, Ekart Logistics, SMS Provider (MSG91), Email Provider (SendGrid), AWS/GCP Cloud, Akamai CDN</ExternalDependencies><HighLevelSystemDescription>Microservices-based e-commerce platform modeled on Flipkart architecture: API Gateway (Kong/Zuul), User/Auth Service with OTP login, Product/Search Service with Elasticsearch, Cart/Checkout, Order Management, Payment Service (Razorpay/PayU), Seller Portal, Notification Service, and Ekart Logistics integration.</HighLevelSystemDescription><Owner>Student</Owner><Reviewer/><ThreatModelName>Flipkart E-commerce Platform - STRIDE Threat Model</ThreatModelName></MetaInformation><Notes/><ThreatInstances xmlns:a="http://schemas.microsoft.com/2003/10/Serialization/Arrays"><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T1e1000001-1111-4e01-a001-e10000000001f1000001-0001-4f01-af01-f10000000001b1010001-0001-4b01-ab01-010000000001</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1000001-0001-4f01-af01-f10000000001</b:FlowGuid><b:Id>1</b:Id><b:InteractionKey>e1000001-1111-4e01-a001-e10000000001:f1000001-0001-4f01-af01-f10000000001:b1010001-0001-4b01-ab01-010000000001</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T01 - API Gateway Request Smuggling</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker crafts ambiguous HTTP requests to bypass Kong/Zuul gateway routing rules and reach internal microservices directly, potentially accessing admin-only endpoints.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker crafts ambiguous HTTP requests to bypass Kong/Zuul gateway routing rules and reach internal microservices directly, potentially accessing admin-only endpoints.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F1 HTTPS (Customer Requests)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>e1000001-1111-4e01-a001-e10000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Normalize and validate HTTP requests at gateway, disable HTTP/1.0, enforce strict parsing, and run regular smuggling tests.</b:StateInformation><b:TargetGuid>b1010001-0001-4b01-ab01-010000000001</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S1b1010001-0001-4b01-ab01-010000000001f1100011-0011-4f11-af11-f11000000011b2020002-0002-4b02-ab02-020000000002</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100011-0011-4f11-af11-f11000000011</b:FlowGuid><b:Id>2</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100011-0011-4f11-af11-f11000000011:b2020002-0002-4b02-ab02-020000000002</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T02 - OTP Brute-Force on Flipkart Login</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Flipkart uses OTP-based mobile login. Attacker automates rapid OTP guesses (4-6 digit) against /api/auth/verify-otp to take over accounts without knowing the password.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Flipkart uses OTP-based mobile login. Attacker automates rapid OTP guesses (4-6 digit) against /api/auth/verify-otp to take over accounts without knowing the password.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Auth/Login API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: High | Impact: High | Mitigation: Rate-limit OTP attempts per phone number, enforce exponential backoff, use CAPTCHA after failed attempts, and expire OTPs within 60 seconds.</b:StateInformation><b:TargetGuid>b2020002-0002-4b02-ab02-020000000002</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S2b1010001-0001-4b01-ab01-010000000001f1100011-0011-4f11-af11-f11000000011b2020002-0002-4b02-ab02-020000000002</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100011-0011-4f11-af11-f11000000011</b:FlowGuid><b:Id>3</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100011-0011-4f11-af11-f11000000011:b2020002-0002-4b02-ab02-020000000002</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T03 - Credential Stuffing on Email/Password Login</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker uses leaked credential databases to automate login attempts against Flipkart accounts that still use email/password.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker uses leaked credential databases to automate login attempts against Flipkart accounts that still use email/password.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Auth/Login API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: High | Impact: High | Mitigation: Breached-password detection, adaptive MFA, device fingerprinting, and account lockout after repeated failures.</b:StateInformation><b:TargetGuid>b2020002-0002-4b02-ab02-020000000002</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T2b1010001-0001-4b01-ab01-010000000001f1100010-0010-4f10-af10-f11000000010b5050005-0005-4b05-ab05-050000000005</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100010-0010-4f10-af10-f11000000010</b:FlowGuid><b:Id>4</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100010-0010-4f10-af10-f11000000010:b5050005-0005-4b05-ab05-050000000005</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T04 - Price/Coupon Tampering During Checkout</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker intercepts Flipkart checkout API calls and modifies cart total, discount amount, or coupon code in the request body to pay less than the actual price.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker intercepts Flipkart checkout API calls and modifies cart total, discount amount, or coupon code in the request body to pay less than the actual price.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Cart/Checkout API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Server-side price recalculation from catalog DB, signed cart tokens, coupon validation on backend, and re-verify totals before payment.</b:StateInformation><b:TargetGuid>b5050005-0005-4b05-ab05-050000000005</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>E1b6060006-0006-4b06-ab06-060000000006fbc00003-0003-4f03-af03-fb0000000003c3d30003-d003-4c03-ac03-d30000000003</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>fbc00003-0003-4f03-af03-fb0000000003</b:FlowGuid><b:Id>5</b:Id><b:InteractionKey>b6060006-0006-4b06-ab06-060000000006:fbc00003-0003-4f03-af03-fb0000000003:c3d30003-d003-4c03-ac03-d30000000003</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T05 - IDOR on Order Details and Address Endpoints</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Elevation Of Privilege</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Authenticated customer changes orderId or addressId in /api/orders/{id} or /api/address/{id} to view or modify another user&apos;s order details, delivery address, or phone number.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Authenticated customer changes orderId or addressId in /api/orders/{id} or /api/address/{id} to view or modify another user&apos;s order details, delivery address, or phone number.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>SQL (Order CRUD)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b6060006-0006-4b06-ab06-060000000006</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: High | Impact: High | Mitigation: Enforce object-level authorization: verify that the requesting user owns the resource on every API call. Use UUIDs instead of sequential IDs.</b:StateInformation><b:TargetGuid>c3d30003-d003-4c03-ac03-d30000000003</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>E1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S3e2000002-2222-4e02-a002-e20000000002f2000002-0002-4f02-af02-f20000000002b1010001-0001-4b01-ab01-010000000001</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f2000002-0002-4f02-af02-f20000000002</b:FlowGuid><b:Id>6</b:Id><b:InteractionKey>e2000002-2222-4e02-a002-e20000000002:f2000002-0002-4f02-af02-f20000000002:b1010001-0001-4b01-ab01-010000000001</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T06 - Fake Seller Registration and Listing Fraud</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker registers as a seller with stolen GST/PAN details, lists counterfeit or non-existent products at attractive prices, collects payments, and never ships goods.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker registers as a seller with stolen GST/PAN details, lists counterfeit or non-existent products at attractive prices, collects payments, and never ships goods.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F2 HTTPS (Seller Portal Requests)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>e2000002-2222-4e02-a002-e20000000002</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: KYC verification (video, bank account, GST validation), seller escrow with delayed payouts, and automated fraud scoring.</b:StateInformation><b:TargetGuid>b1010001-0001-4b01-ab01-010000000001</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S4e4000004-4444-4e04-a004-e40000000004f4000005-0005-4f05-af05-f40000000005b7070007-0007-4b07-ab07-070000000007</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f4000005-0005-4f05-af05-f40000000005</b:FlowGuid><b:Id>7</b:Id><b:InteractionKey>e4000004-4444-4e04-a004-e40000000004:f4000005-0005-4f05-af05-f40000000005:b7070007-0007-4b07-ab07-070000000007</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T07 - Razorpay/PayU Webhook Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker forges a payment success webhook to /api/payment/callback causing Flipkart to mark an unpaid order as paid and ship the product.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker forges a payment success webhook to /api/payment/callback causing Flipkart to mark an unpaid order as paid and ship the product.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F4 Webhook (Payment Callback)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>e4000004-4444-4e04-a004-e40000000004</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Verify webhook HMAC signatures using shared secret, validate payment amount matches order total, and perform server-to-server verification with Razorpay Orders API.</b:StateInformation><b:TargetGuid>b7070007-0007-4b07-ab07-070000000007</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I1b2020002-0002-4b02-ab02-020000000002fba00001-0001-4f01-af01-fb0000000001c1d10001-d001-4c01-ac01-d10000000001</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>fba00001-0001-4f01-af01-fb0000000001</b:FlowGuid><b:Id>8</b:Id><b:InteractionKey>b2020002-0002-4b02-ab02-020000000002:fba00001-0001-4f01-af01-fb0000000001:c1d10001-d001-4c01-ac01-d10000000001</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T08 - Mass User PII Exposure (Phone, Aadhaar, Address)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Database breach or misconfigured backup exposes 400M+ user records including phone numbers, delivery addresses, and saved payment methods to attackers.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Database breach or misconfigured backup exposes 400M+ user records including phone numbers, delivery addresses, and saved payment methods to attackers.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>SQL (User CRUD, Password Hash)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b2020002-0002-4b02-ab02-020000000002</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Encrypt sensitive columns (AES-256), use envelope encryption with AWS KMS, restrict DB access via IAM, encrypt backups, and implement data masking for non-production environments.</b:StateInformation><b:TargetGuid>c1d10001-d001-4c01-ac01-d10000000001</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T3b3030003-0003-4b03-ab03-030000000003fbb00002-0002-4f02-af02-fb0000000002c2d20002-d002-4c02-ac02-d20000000002</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>fbb00002-0002-4f02-af02-fb0000000002</b:FlowGuid><b:Id>9</b:Id><b:InteractionKey>b3030003-0003-4b03-ab03-030000000003:fbb00002-0002-4f02-af02-fb0000000002:c2d20002-d002-4c02-ac02-d20000000002</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T09 - SQL Injection on Product Search/Filter</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker injects SQL via search query, price range filter, or sort parameter on /api/products/search to extract product catalog data, seller information, or pricing strategies.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker injects SQL via search query, price range filter, or sort parameter on /api/products/search to extract product catalog data, seller information, or pricing strategies.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>SQL/ES (Product Search)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b3030003-0003-4b03-ab03-030000000003</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Use parameterized queries for MySQL, validate Elasticsearch query DSL, sanitize all filter inputs, and use ORM (Hibernate) consistently.</b:StateInformation><b:TargetGuid>c2d20002-d002-4c02-ac02-d20000000002</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>D1b1010001-0001-4b01-ab01-010000000001f1100010-0010-4f10-af10-f11000000010b5050005-0005-4b05-ab05-050000000005</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100010-0010-4f10-af10-f11000000010</b:FlowGuid><b:Id>10</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100010-0010-4f10-af10-f11000000010:b5050005-0005-4b05-ab05-050000000005</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T10 - Flash Sale DDoS (Big Billion Days)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Denial Of Service</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>During Flipkart Big Billion Days sale, attackers or scalper bots flood the cart/checkout APIs with millions of requests to exhaust inventory holds and crash the checkout pipeline.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>During Flipkart Big Billion Days sale, attackers or scalper bots flood the cart/checkout APIs with millions of requests to exhaust inventory holds and crash the checkout pipeline.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Cart/Checkout API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: High | Impact: High | Mitigation: CDN-level DDoS protection (Akamai), rate limiting per user/IP, queue-based checkout (virtual waiting room), bot detection via device fingerprinting, and auto-scaling cart microservice.</b:StateInformation><b:TargetGuid>b5050005-0005-4b05-ab05-050000000005</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>D1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T4b1010001-0001-4b01-ab01-010000000001f1100012-0012-4f12-af12-f11000000012b3030003-0003-4b03-ab03-030000000003</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100012-0012-4f12-af12-f11000000012</b:FlowGuid><b:Id>11</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100012-0012-4f12-af12-f11000000012:b3030003-0003-4b03-ab03-030000000003</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T11 - Stored XSS in Product Reviews and Q&amp;A</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker posts a product review or Q&amp;A answer containing JavaScript that executes in other customers&apos; browsers, stealing session tokens or redirecting to phishing pages.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker posts a product review or Q&amp;A answer containing JavaScript that executes in other customers&apos; browsers, stealing session tokens or redirecting to phishing pages.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Product/Search API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: Medium | Mitigation: Server-side HTML sanitization (OWASP Java HTML Sanitizer), output encoding, strict CSP headers, and review moderation pipeline.</b:StateInformation><b:TargetGuid>b3030003-0003-4b03-ab03-030000000003</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T4</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I2b7070007-0007-4b07-ab07-070000000007fbd00004-0004-4f04-af04-fb0000000004c4d40004-d004-4c04-ac04-d40000000004</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>fbd00004-0004-4f04-af04-fb0000000004</b:FlowGuid><b:Id>12</b:Id><b:InteractionKey>b7070007-0007-4b07-ab07-070000000007:fbd00004-0004-4f04-af04-fb0000000004:c4d40004-d004-4c04-ac04-d40000000004</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T12 - Payment Card Data Exposure (PCI DSS Violation)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Saved card details (CVV, full PAN) stored in plaintext in payment ledger or application logs, leading to mass card fraud if breached.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Saved card details (CVV, full PAN) stored in plaintext in payment ledger or application logs, leading to mass card fraud if breached.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>SQL (Payment Records)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b7070007-0007-4b07-ab07-070000000007</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Low | Impact: High | Mitigation: Tokenize card data via Razorpay vault, never store CVV, truncate PAN to last 4 digits, achieve PCI DSS Level 1 compliance, and scan logs for accidental card data leakage.</b:StateInformation><b:TargetGuid>c4d40004-d004-4c04-ac04-d40000000004</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S5e3000003-3333-4e03-a003-e30000000003f3000003-0003-4f03-af03-f30000000003b1010001-0001-4b01-ab01-010000000001</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f3000003-0003-4f03-af03-f30000000003</b:FlowGuid><b:Id>13</b:Id><b:InteractionKey>e3000003-3333-4e03-a003-e30000000003:f3000003-0003-4f03-af03-f30000000003:b1010001-0001-4b01-ab01-010000000001</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T13 - Admin Account Phishing and Session Hijack</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker sends targeted phishing email to Flipkart admin, stealing credentials or admin session cookie to access seller payout controls, catalog management, and user data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker sends targeted phishing email to Flipkart admin, stealing credentials or admin session cookie to access seller payout controls, catalog management, and user data.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F3 HTTPS/VPN (Admin Requests)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>e3000003-3333-4e03-a003-e30000000003</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Hardware security keys (FIDO2) for admin login, admin-only VPN, session binding to IP/device, privileged access management (PAM), and just-in-time access elevation.</b:StateInformation><b:TargetGuid>b1010001-0001-4b01-ab01-010000000001</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T5b1010001-0001-4b01-ab01-010000000001f1100013-0013-4f13-af13-f11000000013b4040004-0004-4b04-ab04-040000000004</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100013-0013-4f13-af13-f11000000013</b:FlowGuid><b:Id>14</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100013-0013-4f13-af13-f11000000013:b4040004-0004-4b04-ab04-040000000004</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T14 - Seller Inventory and Price Manipulation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Compromised seller account or API key is used to bulk-update product prices to 1 INR or inflate stock counts to win Buy Box placement unfairly.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Compromised seller account or API key is used to bulk-update product prices to 1 INR or inflate stock counts to win Buy Box placement unfairly.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Seller Portal API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: Medium | Mitigation: Anomaly detection on price/stock changes (&gt;50% deviation triggers review), seller API rate limits, and mandatory 2FA for bulk updates.</b:StateInformation><b:TargetGuid>b4040004-0004-4b04-ab04-040000000004</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T5</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R1b6060006-0006-4b06-ab06-060000000006f5000006-0006-4f06-af06-f50000000006e5000005-5555-4e05-a005-e50000000005</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f5000006-0006-4f06-af06-f50000000006</b:FlowGuid><b:Id>15</b:Id><b:InteractionKey>b6060006-0006-4b06-ab06-060000000006:f5000006-0006-4f06-af06-f50000000006:e5000005-5555-4e05-a005-e50000000005</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T15 - Delivery Dispute: Customer Denies Receipt</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Customer claims product was not delivered despite successful handoff. Without signed proof of delivery, Flipkart must refund and absorb the loss.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Customer claims product was not delivered despite successful handoff. Without signed proof of delivery, Flipkart must refund and absorb the loss.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F5 Shipping API (Dispatch/Tracking)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b6060006-0006-4b06-ab06-060000000006</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: Medium | Mitigation: OTP-verified delivery, photo proof of delivery via Ekart app, GPS-stamped delivery events, and centralized dispute audit trail.</b:StateInformation><b:TargetGuid>e5000005-5555-4e05-a005-e50000000005</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R1</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R2b6060006-0006-4b06-ab06-060000000006fbf00006-0006-4f06-af06-fb0000000006c6d60006-d006-4c06-ac06-d60000000006</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>fbf00006-0006-4f06-af06-fb0000000006</b:FlowGuid><b:Id>16</b:Id><b:InteractionKey>b6060006-0006-4b06-ab06-060000000006:fbf00006-0006-4f06-af06-fb0000000006:c6d60006-d006-4c06-ac06-d60000000006</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T16 - Audit Log Tampering or Deletion</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Insider or attacker with DB access deletes or modifies audit logs to cover tracks after unauthorized data access or fraudulent refund processing.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Insider or attacker with DB access deletes or modifies audit logs to cover tracks after unauthorized data access or fraudulent refund processing.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Logstash (Audit Events)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b6060006-0006-4b06-ab06-060000000006</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Low | Impact: Medium | Mitigation: Write-once append-only log storage, ship logs to centralized SIEM (Splunk/ELK) in real-time, cryptographic log integrity (hash chains), and separate log-admin role.</b:StateInformation><b:TargetGuid>c6d60006-d006-4c06-ac06-d60000000006</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R2</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>I3e1000001-1111-4e01-a001-e10000000001f1000001-0001-4f01-af01-f10000000001b1010001-0001-4b01-ab01-010000000001</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1000001-0001-4f01-af01-f10000000001</b:FlowGuid><b:Id>17</b:Id><b:InteractionKey>e1000001-1111-4e01-a001-e10000000001:f1000001-0001-4f01-af01-f10000000001:b1010001-0001-4b01-ab01-010000000001</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>High</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T17 - Session Token Leakage from Mobile App</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Information Disclosure</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Flipkart Android/iOS app stores JWT or session token in SharedPreferences/NSUserDefaults without encryption. Malware or rooted device extracts tokens for account takeover.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Flipkart Android/iOS app stores JWT or session token in SharedPreferences/NSUserDefaults without encryption. Malware or rooted device extracts tokens for account takeover.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F1 HTTPS (Customer Requests)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>High</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>e1000001-1111-4e01-a001-e10000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: High | Mitigation: Store tokens in Android Keystore / iOS Keychain, use certificate pinning, detect rooted/jailbroken devices, and bind tokens to device fingerprint.</b:StateInformation><b:TargetGuid>b1010001-0001-4b01-ab01-010000000001</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>I3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>T6b1010001-0001-4b01-ab01-010000000001f1100010-0010-4f10-af10-f11000000010b5050005-0005-4b05-ab05-050000000005</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100010-0010-4f10-af10-f11000000010</b:FlowGuid><b:Id>18</b:Id><b:InteractionKey>b1010001-0001-4b01-ab01-010000000001:f1100010-0010-4f10-af10-f11000000010:b5050005-0005-4b05-ab05-050000000005</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T18 - Cart Bombing / Inventory Hold Abuse</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Tampering</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker adds limited-stock flash sale items to thousands of carts via automated scripts, holding inventory without purchasing to deny legitimate buyers access.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker adds limited-stock flash sale items to thousands of carts via automated scripts, holding inventory without purchasing to deny legitimate buyers access.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>Route: Cart/Checkout API</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b1010001-0001-4b01-ab01-010000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: Medium | Mitigation: Short cart reservation timeouts (5 min for flash sales), per-user quantity limits, bot detection (CAPTCHA on add-to-cart during sales), and inventory release on timeout.</b:StateInformation><b:TargetGuid>b5050005-0005-4b05-ab05-050000000005</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>T6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>S6e1000001-1111-4e01-a001-e10000000001f1000001-0001-4f01-af01-f10000000001b1010001-0001-4b01-ab01-010000000001</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1000001-0001-4f01-af01-f10000000001</b:FlowGuid><b:Id>19</b:Id><b:InteractionKey>e1000001-1111-4e01-a001-e10000000001:f1000001-0001-4f01-af01-f10000000001:b1010001-0001-4b01-ab01-010000000001</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T19 - Mobile App API Key Extraction</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Spoofing</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Attacker reverse-engineers Flipkart APK to extract API keys, client secrets, or hardcoded credentials used for internal service authentication.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Attacker reverse-engineers Flipkart APK to extract API keys, client secrets, or hardcoded credentials used for internal service authentication.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F1 HTTPS (Customer Requests)</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>e1000001-1111-4e01-a001-e10000000001</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: Medium | Mitigation: Use OAuth2 device flow instead of embedded secrets, obfuscate APK (ProGuard/R8), rotate API keys frequently, and monitor for anomalous API key usage patterns.</b:StateInformation><b:TargetGuid>b1010001-0001-4b01-ab01-010000000001</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>S6</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB><a:KeyValueOfstringThreatpc_P0_PhOB><a:Key>R3b6060006-0006-4b06-ab06-060000000006f1100015-0015-4f15-af15-f11000000015b7070007-0007-4b07-ab07-070000000007</a:Key><a:Value xmlns:b="http://schemas.datacontract.org/2004/07/ThreatModeling.KnowledgeBase"><b:ChangedBy>Student</b:ChangedBy><b:DrawingSurfaceGuid>d8c8aab1-5108-49c5-92a1-b214ba353477</b:DrawingSurfaceGuid><b:FlowGuid>f1100015-0015-4f15-af15-f11000000015</b:FlowGuid><b:Id>20</b:Id><b:InteractionKey>b6060006-0006-4b06-ab06-060000000006:f1100015-0015-4f15-af15-f11000000015:b7070007-0007-4b07-ab07-070000000007</b:InteractionKey><b:InteractionString i:nil="true"/><b:ModifiedAt>2026-05-31T00:00:00</b:ModifiedAt><b:Priority>Medium</b:Priority><b:Properties><a:KeyValueOfstringstring><a:Key>Title</a:Key><a:Value>T20 - Refund Fraud with Insufficient Evidence</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatCategory</a:Key><a:Value>Repudiation</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatShortDescription</a:Key><a:Value>Customer or seller disputes a transaction. Without signed receipts, delivery proof, or immutable payment logs, Flipkart cannot prove the transaction occurred, leading to chargebacks.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>UserThreatDescription</a:Key><a:Value>Customer or seller disputes a transaction. Without signed receipts, delivery proof, or immutable payment logs, Flipkart cannot prove the transaction occurred, leading to chargebacks.</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>InteractionString</a:Key><a:Value>F9 Payment Request</a:Value></a:KeyValueOfstringstring><a:KeyValueOfstringstring><a:Key>Priority</a:Key><a:Value>Medium</a:Value></a:KeyValueOfstringstring></b:Properties><b:SourceGuid>b6060006-0006-4b06-ab06-060000000006</b:SourceGuid><b:State>Needs Investigation</b:State><b:StateInformation>Likelihood: Medium | Impact: Medium | Mitigation: Store signed payment receipts, maintain immutable transaction ledger, integrate Razorpay dispute evidence API, and implement automated chargeback response.</b:StateInformation><b:TargetGuid>b7070007-0007-4b07-ab07-070000000007</b:TargetGuid><b:Title i:nil="true"/><b:TypeId>R3</b:TypeId><b:Upgraded>false</b:Upgraded><b:UserThreatCategory i:nil="true"/><b:UserThreatDescription i:nil="true"/><b:UserThreatShortDescription i:nil="true"/><b:Wide>false</b:Wide></a:Value></a:KeyValueOfstringThreatpc_P0_PhOB></ThreatInstances><Kn